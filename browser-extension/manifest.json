{
  "manifest_version": 3,
  "name": "拾迹 TraceNest",
  "description": "随手收藏网页与文字，让零散信息进入你的知识与成长轨迹。",
  "version": "0.1.0",
  "minimum_chrome_version": "109",
  "permissions": ["activeTab", "alarms", "contextMenus", "notifications", "scripting", "storage"],
  "host_permissions": ["https://tracenest-memory.luoxinrong2026.chatgpt.site/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "收藏到拾迹",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
